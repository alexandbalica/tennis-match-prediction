    "# Predictions from the chosen model\n",
    "y_pred = model_3.predict(X_test)\n",
    "\n",
    "# Build a results dataframe using the original indices\n",
    "results_df = df_with_names.loc[X_test.index].copy()\n",
    "\n",
    "# Add predictions and true labels\n",
    "results_df['true'] = y_test.values\n",
    "results_df['pred'] = y_pred\n",
    "\n",
    "# Correct predictions\n",
    "correct = results_df[results_df['true'] == results_df['pred']]\n",
    "\n",
    "# Incorrect predictions\n",
    "incorrect = results_df[results_df['true'] != results_df['pred']]\n",
    "\n",
    "# Show examples\n",
    "print(\"Correct predictions:\")\n",
    "display(correct[['player', 'opponent', 'true', 'pred'] + list(X_test.columns)].sample(3, random_state=42))\n",
    "\n",
    "print(\"Incorrect predictions:\")\n",
    "display(incorrect[['player', 'opponent', 'true', 'pred'] + list(X_test.columns)].sample(3, random_state=42))"
